services:
  ollama:
    image: ollama/ollama:${OLLAMA_VERSION:-latest}
    container_name: ollama
    networks:
      - ai-network
    ports:
      - "${OLLAMA_BIND_ADDRESS:-127.0.0.1}:${OLLAMA_PORT:-11434}:11434"
    environment:
      - TZ=${OLLAMA_TZ:-Asia/Shanghai}
      # Go 运行时通过 ZONEINFO 查找时区数据文件，确保 time.Now() 返回本地时间
      - ZONEINFO=/usr/share/zoneinfo
      - OLLAMA_HOST=0.0.0.0
      - NVIDIA_VISIBLE_DEVICES=all
      - OLLAMA_FLASH_ATTENTION=1

      #====== 针对120GB VRAM的关键调优 ======#

      # 1. 并行处理能力（每个模型同时处理的并发请求数）
      #    决定多核CPU利用率：每个并行请求独立使用CPU线程池进行推理
      #    llama.cpp 底层会自动利用所有可用CPU核心 (通过OpenMP/线程池)
      - OLLAMA_NUM_PARALLEL=${OLLAMA_NUM_PARALLEL:-8}

      # 2. 请求队列最大长度（超出返回503，防止过载）
      - OLLAMA_MAX_QUEUE=${OLLAMA_MAX_QUEUE:-512}

      # 3. 同时驻留更多模型（避免频繁加载/卸载）
      - OLLAMA_MAX_LOADED_MODELS=${OLLAMA_MAX_LOADED_MODELS:-4}

      # 4. 模型保持时间延长（统一内存下切换成本低，但驻留更划算）
      - OLLAMA_KEEP_ALIVE=${OLLAMA_KEEP_ALIVE:-30m}

      # 5. 显式设置大上下文（日志显示自动推算为262K，可手动确认）
      - OLLAMA_CONTEXT_LENGTH=${OLLAMA_CONTEXT_LENGTH:-131072}

      # 6. KV缓存使用半精度（节省显存，几乎不影响质量）
      - OLLAMA_KV_CACHE_TYPE=${OLLAMA_KV_CACHE_TYPE:-q8_0}

      # 7. 调试级别（稳定后改为WARN减少日志量）
      - OLLAMA_DEBUG=${OLLAMA_DEBUG:-INFO}

    volumes:
      - ${OLLAMA_DATA_DIR:-/opt/ai/ollama/ollama_data}:/root/.ollama
      # 时区挂载：直接用 zoneinfo 数据文件而非宿主机 symlink，避免容器内解析异常
      - /usr/share/zoneinfo:/usr/share/zoneinfo:ro
      - /usr/share/zoneinfo/${OLLAMA_TZ:-Asia/Shanghai}:/etc/localtime:ro
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
          cpus: '${OLLAMA_CPU_RESERVATION:-4.0}'
          memory: ${OLLAMA_MEM_RESERVATION:-16G}
        limits:
          # GB10 Grace CPU通常是10核ARM，根据实际调整
          cpus: '${OLLAMA_CPU_LIMIT:-10.0}'
          # 统一内存架构下，容器内存限制需要足够大
          # 因为GPU VRAM和系统内存是同一块物理内存
          memory: ${OLLAMA_MEM_LIMIT:-120G}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:11434/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: ${OLLAMA_START_PERIOD:-120s}
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "5"
    restart: unless-stopped

  # ── Web 管理界面 ──────────────────────────────────────────────
  ollama-web:
    build:
      context: ./web
      dockerfile: Dockerfile
      args:
        VERSION: ${WEB_VERSION:-v1.4.8}
    image: ollama-web:latest
    container_name: ollama-web
    networks:
      - ai-network
    ports:
      - "${WEB_LISTEN_ADDR:-0.0.0.0}:${WEB_PORT:-9981}:8080"
    environment:
      - TZ=${OLLAMA_TZ:-Asia/Shanghai}
      - OLLAMA_API_URL=http://ollama:11434
      - OLLAMA_PROJECT_DIR=/opt/ai/ollama
      - OLLAMA_SCRIPT_PATH=/opt/ai/ollama/ollama.sh
      - WEB_LISTEN_ADDR=0.0.0.0:8080
      - WEB_LOG_LEVEL=${WEB_LOG_LEVEL:-info}
      - WEB_API_KEY=${WEB_API_KEY}
      - WEB_CORS_ORIGIN=${WEB_CORS_ORIGIN:-}
    volumes:
      # 挂载项目目录以访问 ollama.sh、.env、docker-compose.yaml
      - ${OLLAMA_PROJECT_DIR:-/opt/ai/ollama}:/opt/ai/ollama
      # 挂载 Docker socket 以管理容器
      - /var/run/docker.sock:/var/run/docker.sock
    depends_on:
      - ollama
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8080/api/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    restart: unless-stopped

networks:
  ai-network:
    driver: bridge
